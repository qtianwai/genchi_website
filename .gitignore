# 达人美食推荐 App - .gitignore
# 防止敏感信息和无用文件提交到 git

# ── 环境变量和密钥 ──
backend/.env
ios/FoodMap/FoodMap/Config.xcconfig

# ── Python ──
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ── Xcode ──
ios/FoodMap/FoodMap.xcodeproj/project.xcworkspace/
ios/FoodMap/FoodMap.xcodeproj/xcuserdata/
ios/FoodMap/*.xcworkspace/xcuserdata/
DerivedData/
*.xccheckout
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# ── macOS ──
.DS_Store
.AppleDouble
.LSOverride
ios/FoodMap/genchi/genchi.xcodeproj/xcuserdata/
ios/FoodMap/genchi/genchi.xcworkspace/xcuserdata/
ios/FoodMap/genchi/DerivedData/
